@model int

<td style="width:150px">

    <div class="btn-group">

        <a asp-area="Admin"
           asp-action="Edit"
           asp-controller="SpecialTag"
           class="btn btn-primary"
           asp-route-id="@Model">

            <i class="fas fa-edit"></i>

        </a>

        <a asp-area="Admin"
           asp-action="Details"
           asp-controller="SpecialTag"
           class="btn btn-success"
           asp-route-id="@Model">

            <i class="fas fa-list"></i>

        </a>

        <a asp-area="Admin"
           asp-action="Delete"
           asp-controller="SpecialTag"
           class="btn btn-danger"
           asp-route-id="@Model">

            <i class="fas fa-trash-alt"></i>

        </a>

    </div>

</td>