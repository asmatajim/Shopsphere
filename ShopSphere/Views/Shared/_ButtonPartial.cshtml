<a asp-action="Edit" asp-route-id="@Model" class="btn btn-primary btn-sm">
    <i class="fas fa-edit"></i>
</a>

<a asp-action="Details" asp-route-id="@Model" class="btn btn-success btn-sm">
    <i class="fas fa-list"></i>
</a>

<a asp-action="Delete" asp-route-id="@Model" class="btn btn-danger btn-sm">
    <i class="fas fa-trash"></i>
</a>

