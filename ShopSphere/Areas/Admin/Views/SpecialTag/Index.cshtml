@model IEnumerable<ShopSphere.Models.SpecialTag>

@{
    ViewData["Title"] = "Index";
}

<br />
<br />

<div class="row">

    <div class="col-6">
        <h2 class="text-info">Special Tags List</h2>
    </div>

    <div class="col-6 text-end">
        <a asp-action="Create" class="btn btn-info">
            <i class="fas fa-plus"></i> Create Tag
        </a>
    </div>

</div>

<table class="table table-striped border">

    <tr class="table-info">

        <th>Sr. No</th>

        <th>@Html.DisplayNameFor(x => x.Name)</th>

        <th>Action</th>

    </tr>

    @{
        int i = 1;
    }

    @foreach (var item in Model)
    {

        <tr>

            <td>@i</td>

            <td>@item.Name</td>

            <td>
                <partial name="_TagPartial" model="@item.Id" />
            </td>

        </tr>

        i++;

    }

</table>
@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/alertifyjs@1.13.1/build/alertify.min.js"></script>

    <script>

        $(function () {

        alertify.set('notifier', 'position', 'top-right');

        var success = '@TempData["success"]';
        if (success != '') {
        alertify.success(success);
        }

        var deleteMsg = '@TempData["delete"]';
        if (deleteMsg != '') {
        alertify.error(deleteMsg);
        }

        var error = '@TempData["error"]';
        if (error != '') {
        alertify.error(error);
        }

        });

    </script>

}