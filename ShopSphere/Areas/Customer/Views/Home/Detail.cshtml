@model ShopSphere.Models.Products
@using ShopSphere.Utility
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Details";
    List<CartItem> cart = HttpContextAccessor.HttpContext.Session.Get<List<CartItem>>("cart");
    CartItem productInCart = cart?.FirstOrDefault(c => c.Product.Id == Model.Id);
}

<br />

<h2 class="text-info">Product Details</h2>

<div class="p-4 rounded border row">

    <div class="col-8">

        <div class="form-group row">
            <div class="col-4"><label asp-for="Name"></label></div>
            <div class="col-8">
                <input asp-for="Name" readonly class="form-control" />
            </div>
        </div>

        <div class="form-group row">
            <div class="col-4"><label asp-for="Price"></label></div>
            <div class="col-8">
                <input asp-for="Price" readonly class="form-control" />
            </div>
        </div>

        <div class="form-group row">
            <div class="col-4"><label asp-for="ProductColor"></label></div>
            <div class="col-8">
                <input asp-for="ProductColor" readonly class="form-control" />
            </div>
        </div>

        <div class="form-group row">
            <div class="col-4"><label asp-for="ProductTypeId"></label></div>
            <div class="col-8">
                <input asp-for="ProductTypes.ProductType" readonly class="form-control" />
            </div>
        </div>

        <div class="form-group row">
            <div class="col-4"></div>
            <div class="col-8">

                @if (productInCart != null)
                {
                    <form asp-area="Customer" asp-controller="Home" asp-action="RemoveCartItem" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger form-control">
                            Remove from Cart
                        </button>
                    </form>
                }
                else
                {
                    <form asp-area="Customer" asp-controller="Home" asp-action="AddToCart" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-primary form-control">
                            Add To Cart
                        </button>
                    </form>
                }

            </div>
        </div>

        <div class="form-group">
            <a asp-action="Index" class="btn btn-success">Back to List</a>
        </div>

    </div>

    <div class="col-1"></div>

    <div class="col-3">
        <img src="~/@Model.Image" style="width:100%;height:250px;border-radius:5px;border:1px solid #efefef;" />

        @if (Model.IsAvailable)
        {
            <img src="~/Images/instock-logo.png" style="width:200px;height:50px;" />
        }
        else
        {
            <img src="~/Images/notinstock.jpg" style="width:200px;height:50px;" />
        }
    </div>

</div>

<script>

    $("#addToCart").click(function () {

        $.ajax({

            url: '/Customer/Home/Detail/@Model.Id',
            type: 'POST',

            success: function (data) {

                if (data.success) {

                    location.reload();

                }

            }

        });

    });

</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}